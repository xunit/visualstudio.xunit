    <Project Path="src/xunit.runner.visualstudio/xunit.runner.visualstudio.csproj" />
  </Folder>
  <Folder Name="/test/">
    <File Path="test/Directory.Build.props" />
    <File Path="test/Directory.Build.targets" />
    <Project Path="test/test.v1/test.v1.csproj" />
    <Project Path="test/test.v2/test.v2.csproj" />
    <Project Path="test/test.v3/test.v3.csproj" />
    <Project Path="test/test.v3.aot/test.v3.aot.csproj" />
    <Project Path="test/test.xunit.runner.visualstudio/test.xunit.runner.visualstudio.csproj" />
  </Folder>
</Solution>
