<Solution>
  <Folder Name="/git/">
    <File Path=".gitattributes" />
    <File Path=".github/ISSUE_TEMPLATE.md" />
    <File Path=".github/PULL_REQUEST_TEMPLATE.md" />
    <File Path=".gitignore" />
  </Folder>
  <Folder Name="/git/workflows/">
    <File Path=".github/workflows/ci-signed.yaml" />
    <File Path=".github/workflows/ci-unsigned.yaml" />
    <File Path=".github/workflows/pull-request.yaml" />
  </Folder>
  <Folder Name="/meta/">
    <File Path=".editorconfig" />
    <File Path="BUILDING.md" />
    <File Path="NuGet.Config" />
    <File Path="README.md" />
    <File Path="version.json" />
    <File Path="Versions.props" />
  </Folder>
  <Folder Name="/src/">
